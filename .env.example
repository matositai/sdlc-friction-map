# GitHub API Token (required for live data)
# Get from: https://github.com/settings/tokens
# Needs: repo, read:org scopes
GITHUB_TOKEN=ghp_your_token_here

# Claude API Key (required for AI friction analysis)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Upstash Redis (via Vercel Storage) — auto-configured on database connection
# Get from: Vercel Dashboard → Storage → Upstash → Create Database → Connect
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here
