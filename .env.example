# GitHub API Token (required for live data)
# Get from: https://github.com/settings/tokens
# Needs: repo, read:org scopes
GITHUB_TOKEN=ghp_your_token_here

# Claude API Key (required for AI friction analysis)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Vercel KV (Redis) — auto-configured by Vercel on KV creation
# Get from: Vercel Dashboard → Storage → KV → Connect
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your_kv_token_here
